{
  "name": "@vibeloop/cli",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vibeloop": "./bin/vibeloop"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --pretty false",
    "typecheck": "tsc -p tsconfig.json --pretty false",
    "test": "vitest run"
  },
  "dependencies": {
    "@vibeloop/artifacts": "workspace:*",
    "@vibeloop/discovery": "workspace:*",
    "@vibeloop/github-integration": "workspace:*",
    "@vibeloop/report-html": "workspace:*",
    "@vibeloop/sdk": "workspace:*",
    "@vibeloop/shared": "workspace:*",
    "@vibeloop/task-protocol": "workspace:*",
    "commander": "^14.0.2"
  }
}
