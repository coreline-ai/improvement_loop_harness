# Local development defaults. Use DATABASE_URL instead of VIBELOOP_STORE=memory for persistent runs.
VIBELOOP_API_TOKEN=dev-token
VIBELOOP_STORE=memory
VIBELOOP_DATA_DIR=.vibeloop
VIBELOOP_AGENT_SPEC=codex
# DATABASE_URL=postgresql://vibeloop:vibeloop@127.0.0.1:54329/vibeloop
# TEST_DATABASE_URL=postgresql://vibeloop:vibeloop@127.0.0.1:54329/vibeloop
