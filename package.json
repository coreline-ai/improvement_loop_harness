{
  "name": "vibeloop-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -b --pretty false",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test": "vitest run --exclude \"tests/e2e/**\"",
    "test:e2e": "pnpm build && vitest run --passWithNoTests tests/e2e",
    "format": "prettier --check .",
    "clean": "rm -rf packages/*/dist coverage .vibeloop",
    "start:server": "pnpm --filter @vibeloop/server start",
    "test:smoke": "pnpm --filter web test:smoke",
    "build:web": "pnpm --filter web build",
    "test:scenario:user": "pnpm build && vitest run --passWithNoTests tests/e2e/user-scenarios/real-user-flow.e2e.test.ts",
    "uat:codex-proxy": "pnpm build && node scripts/uat/codex-proxy-uat.mjs",
    "uat:codex-oauth": "pnpm build && node scripts/uat/codex-oauth-proxy-uat.mjs",
    "uat:skill-loop": "pnpm build && node scripts/uat/skill-real-user-loop-uat.mjs",
    "test:skill-loop": "pnpm build && vitest run --passWithNoTests tests/e2e/skill-productization/skill-real-user-loop.e2e.test.ts",
    "uat:skill-loop:adversarial": "pnpm build && node scripts/uat/skill-real-user-loop-adversarial-uat.mjs",
    "test:skill-loop:adversarial": "pnpm build && vitest run --passWithNoTests tests/e2e/skill-productization/skill-real-user-loop-adversarial.e2e.test.ts",
    "uat:skill-loop:self-improvement": "pnpm build && node scripts/uat/skill-self-improvement-loop-uat.mjs",
    "test:skill-loop:self-improvement": "pnpm build && vitest run --passWithNoTests tests/e2e/skill-productization/skill-self-improvement-loop.e2e.test.ts",
    "bundle:skill": "pnpm build && node scripts/bundle-skill.mjs",
    "uat:skill-loop:full": "pnpm bundle:skill && node scripts/uat/skill-real-user-full-uat.mjs",
    "uat:skill-loop:codex-live": "pnpm build && node scripts/uat/skill-real-user-codex-live-uat.mjs",
    "uat:skill-loop:codex-skill-prompt": "pnpm build && node scripts/uat/skill-real-user-codex-skill-prompt-uat.mjs",
    "uat:skill-loop:codex-skill-prompt:real-builder": "pnpm build && VIBELOOP_SKILL_PROMPT_UAT_BUILDER=codex node scripts/uat/skill-real-user-codex-skill-prompt-uat.mjs",
    "uat:skill-loop:codex-skill-prompt:auto": "pnpm build && VIBELOOP_SKILL_PROMPT_UAT_MODE=auto_discovery node scripts/uat/skill-real-user-codex-skill-prompt-uat.mjs",
    "uat:skill-loop:codex-skill-prompt:auto:real-builder": "pnpm build && VIBELOOP_SKILL_PROMPT_UAT_MODE=auto_discovery VIBELOOP_SKILL_PROMPT_UAT_BUILDER=codex node scripts/uat/skill-real-user-codex-skill-prompt-uat.mjs",
    "uat:skill-loop:codex-live:multi": "pnpm build && node scripts/uat/skill-real-user-codex-multi-issue-uat.mjs",
    "uat:skill-loop:codex-live:orchestrate": "pnpm build && node scripts/uat/skill-real-user-codex-orchestrate-ru3-uat.mjs",
    "uat:skill-loop:codex-live:strict-best": "pnpm build && node scripts/uat/skill-real-user-codex-strict-best-fix-uat.mjs",
    "uat:skill-loop:codex-live:orchestrate-strict-best": "pnpm build && node scripts/uat/skill-real-user-codex-orchestrate-strict-best-uat.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "prisma": "^7.8.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0"
  }
}
