{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibeloop.dev/schemas/eval.schema.json",
  "title": "VibeLoop Eval Config",
  "type": "object",
  "required": ["schema_version", "project", "gates"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "default": "autonomous-improvement-loop"
    },
    "protected_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "human_approval_risk_areas": {
      "description": "Risk areas that can never be auto-accepted. Renamed from human_approval_required to avoid collision with the boolean field of the same name in task.schema.json.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_classification": {
      "description": "Path-prefix mapping used by the harness to reclassify risk areas from changed files. Keys are risk area names, values are path prefixes.",
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "limits": {
      "description": "Project-wide defaults for the small-patch principle. Stricter of task-level and this applies.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_changed_files": {
          "type": "integer",
          "minimum": 1
        },
        "max_changed_lines": {
          "type": "integer",
          "minimum": 1
        },
        "agent_timeout_seconds": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "test_integrity": {
      "description": "Configuration for the builtin test-integrity guard.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "forbidden_patterns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "suspicious_patterns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "baseline": {
      "description": "Baseline capture policy for improvement-evidence comparison.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["per_loop", "cached_per_base_commit"],
          "default": "cached_per_base_commit"
        }
      }
    },
    "improvement_evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required_any": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "command", "required"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9_:-]+$"
          },
          "type": {
            "type": "string",
            "enum": [
              "hard",
              "scope",
              "integrity",
              "security",
              "task_acceptance",
              "regression",
              "performance",
              "hidden_acceptance",
              "advisory"
            ]
          },
          "command": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 1
          },
          "max_regression_percent": {
            "type": "number"
          },
          "env": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "cwd": {
            "type": "string"
          },
          "group": {
            "type": "string",
            "enum": ["fail_to_pass", "pass_to_pass", "hidden_acceptance"]
          }
        }
      }
    },
    "hidden_acceptance": {
      "description": "Hidden acceptance tests stored outside the target repo. The harness copies them into the candidate worktree only after the agent exits and removes them after evaluation.",
      "type": "object",
      "additionalProperties": false,
      "required": ["tests"],
      "properties": {
        "tests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "source_path", "target_path"],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z0-9_:-]+$"
              },
              "source_path": {
                "type": "string",
                "minLength": 1
              },
              "target_path": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "policy": {
          "type": "string",
          "enum": ["local", "strict"],
          "default": "local"
        }
      }
    },
    "critic": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "require_different_provider": {
          "type": "boolean",
          "default": false
        },
        "reviewer_provider": {
          "type": "string",
          "description": "Declared provider of the advisory reviewer (e.g. openai, anthropic). When it differs from the builder provider the advisory review is treated as independent; unset keeps same_model_review conservative."
        }
      }
    },
    "evaluator": {
      "description": "Deterministic improvement-quality gate (M0). Fixed-rule thresholds computed from harness artifacts, never an LLM judgment. When absent, quality is treated as met (no behavior change). See docs/SELF_IMPROVEMENT_LOOP_DESIGN.md §8/§9.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "boolean",
          "description": "When true, PR candidacy requires quality.met (consumed by the PR gate).",
          "default": false
        },
        "max_changed_files": {
          "type": "integer",
          "minimum": 1
        },
        "max_changed_lines": {
          "type": "integer",
          "minimum": 1
        },
        "forbid_protected": {
          "type": "boolean",
          "default": true
        },
        "min_evidence_present": {
          "type": "integer",
          "minimum": 0,
          "default": 1
        },
        "require_test_on_base_pass": {
          "type": "boolean",
          "default": false
        },
        "target_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "artifact_leak": {
      "description": "Deterministic agent stdout/stderr context-leak guard. When present, the harness scans the bounded agent stdout/stderr and redacts matches before persisting. Add a builtin:artifact-leak gate to make the verdict reject on a forbidden literal (and, if opted in, a token-like match). Absent = no scan/redaction.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scan_agent_stdout": { "type": "boolean", "default": true },
        "scan_agent_stderr": { "type": "boolean", "default": true },
        "scan_patch": {
          "type": "boolean",
          "default": false,
          "description": "v2: scan the candidate patch (PR deliverable) for forbidden literals / opted-in tokens. The patch is never redacted; a match rejects the candidate."
        },
        "redact_gate_logs": {
          "type": "boolean",
          "default": false,
          "description": "v2: redact-only the project gate stdout/stderr logs before persisting (no reject; gate pass/fail unaffected)."
        },
        "max_scan_bytes": {
          "type": "integer",
          "minimum": 1,
          "default": 1048576
        },
        "forbidden_literals": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "value"],
            "properties": {
              "label": { "type": "string", "minLength": 1 },
              "value": { "type": "string", "minLength": 1 }
            }
          }
        },
        "builtins": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "token_like": { "type": "boolean", "default": false }
          }
        }
      }
    }
  }
}
