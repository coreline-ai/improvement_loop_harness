{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibeloop.dev/schemas/eval-report.schema.json",
  "title": "VibeLoop Eval Report",
  "type": "object",
  "required": [
    "schema_version",
    "loop_id",
    "task_id",
    "base_commit",
    "decision",
    "gate_runs",
    "changed_files",
    "decision_reasons",
    "improvement_evidence",
    "artifact_refs"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0", "1.1"]
    },
    "loop_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "base_commit": {
      "type": "string"
    },
    "candidate_commit": {
      "type": ["string", "null"]
    },
    "decision": {
      "type": "string",
      "enum": ["accept", "reject", "needs_human_review", "needs_more_tests"]
    },
    "decision_reasons": {
      "description": "Machine-readable reasons from the decision engine's first-match-wins rule table. Not free-form strings.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "additionalProperties": false,
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "ref": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "status", "allowed_by_write_scope", "protected"],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "added",
              "modified",
              "deleted",
              "renamed",
              "copied",
              "untracked"
            ]
          },
          "old_path": {
            "type": ["string", "null"]
          },
          "allowed_by_write_scope": {
            "type": "boolean"
          },
          "protected": {
            "type": "boolean"
          }
        }
      }
    },
    "gate_runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "required", "status", "exit_code"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "command": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "skipped", "error"]
          },
          "exit_code": {
            "type": ["integer", "null"]
          },
          "duration_ms": {
            "type": ["integer", "null"]
          },
          "stdout_ref": {
            "type": ["string", "null"]
          },
          "stderr_ref": {
            "type": ["string", "null"]
          },
          "summary": {
            "type": ["string", "null"]
          },
          "group": {
            "type": "string",
            "enum": ["fail_to_pass", "pass_to_pass", "hidden_acceptance"]
          }
        }
      }
    },
    "improvement_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "status"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["present", "missing", "inconclusive"]
          },
          "artifact_ref": {
            "type": ["string", "null"]
          },
          "supporting_gate": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "areas": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "human_approval_required": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "advisory_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "harness_version",
        "decision_engine_version",
        "task_hash",
        "eval_config_hash",
        "candidate_patch_hash",
        "gate_artifact_hashes",
        "generated_by"
      ],
      "properties": {
        "harness_version": {
          "type": "string"
        },
        "decision_engine_version": {
          "type": "string"
        },
        "task_hash": {
          "type": "string"
        },
        "eval_config_hash": {
          "type": "string"
        },
        "candidate_patch_hash": {
          "type": "string"
        },
        "gate_artifact_hashes": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "generated_by": {
          "type": "string",
          "const": "harness"
        }
      }
    },
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy", "lanes", "mismatch"],
      "properties": {
        "policy": {
          "type": "string",
          "enum": ["local", "strict"]
        },
        "mismatch": {
          "type": "boolean"
        },
        "lanes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["lane", "status", "decision", "required_gates"],
            "properties": {
              "lane": {
                "type": "string",
                "enum": ["local", "ci", "external"]
              },
              "status": {
                "type": "string",
                "enum": ["pass", "fail", "missing", "mismatch"]
              },
              "decision": {
                "type": ["string", "null"]
              },
              "required_gates": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["name", "status"],
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    }
                  }
                }
              },
              "artifact_ref": {
                "type": ["string", "null"]
              },
              "summary": {
                "type": ["string", "null"]
              }
            }
          }
        }
      }
    },
    "trust_summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "deterministic_authority": {
          "type": "string"
        },
        "advisory_findings_count": {
          "type": "integer",
          "minimum": 0
        },
        "optional_gate_errors_count": {
          "type": "integer",
          "minimum": 0
        },
        "provenance_verified": {
          "type": "boolean"
        },
        "hidden_acceptance_status": {
          "type": "string"
        },
        "verifier_status": {
          "type": "string"
        },
        "human_review_reason_code": {
          "type": ["string", "null"]
        }
      }
    },
    "rulepack_semantic": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "status", "total", "passed", "results", "errors"],
        "properties": {
          "file": {
            "type": "string"
          },
          "lock_hash": {
            "type": ["string", "null"]
          },
          "source_loop_id": {
            "type": ["string", "null"]
          },
          "current_loop_id": {
            "type": ["string", "null"]
          },
          "image": {
            "type": "string"
          },
          "network": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "error"]
          },
          "total": {
            "type": "integer",
            "minimum": 0
          },
          "passed": {
            "type": "integer",
            "minimum": 0
          },
          "artifact_ref": {
            "type": ["string", "null"]
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "rule_id",
                "status",
                "expected",
                "actual",
                "summary"
              ],
              "properties": {
                "rule_id": {
                  "type": "string"
                },
                "status": {
                  "type": "string",
                  "enum": ["pass", "fail", "error"]
                },
                "expected": {
                  "type": "string"
                },
                "actual": {
                  "type": "string"
                },
                "summary": {
                  "type": "string"
                }
              }
            }
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["code", "message"],
              "properties": {
                "code": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                },
                "rule_id": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "schema_version": {
            "const": "1.1"
          }
        },
        "required": ["schema_version"]
      },
      "then": {
        "required": ["provenance"]
      }
    }
  ]
}
