{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibeloop.dev/schemas/eval-report.schema.json",
  "title": "VibeLoop Eval Report",
  "type": "object",
  "required": [
    "schema_version",
    "loop_id",
    "task_id",
    "base_commit",
    "decision",
    "gate_runs",
    "changed_files",
    "decision_reasons",
    "improvement_evidence",
    "artifact_refs"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "loop_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "base_commit": {
      "type": "string"
    },
    "candidate_commit": {
      "type": [
        "string",
        "null"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "accept",
        "reject",
        "needs_human_review",
        "needs_more_tests"
      ]
    },
    "decision_reasons": {
      "description": "Machine-readable reasons from the decision engine's first-match-wins rule table. Not free-form strings.",
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "additionalProperties": false,
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "ref": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "status",
          "allowed_by_write_scope",
          "protected"
        ],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "added",
              "modified",
              "deleted",
              "renamed",
              "copied",
              "untracked"
            ]
          },
          "old_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "allowed_by_write_scope": {
            "type": "boolean"
          },
          "protected": {
            "type": "boolean"
          }
        }
      }
    },
    "gate_runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "type",
          "required",
          "status",
          "exit_code"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "command": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "skipped",
              "error"
            ]
          },
          "exit_code": {
            "type": [
              "integer",
              "null"
            ]
          },
          "duration_ms": {
            "type": [
              "integer",
              "null"
            ]
          },
          "stdout_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "stderr_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "summary": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "improvement_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "status"
        ],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "present",
              "missing",
              "inconclusive"
            ]
          },
          "artifact_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "supporting_gate": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "areas": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "human_approval_required": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "advisory_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string"
    }
  }
}
